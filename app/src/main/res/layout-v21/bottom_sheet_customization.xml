<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/main_activity_bg"
    android:clickable="true"
    app:behavior_hideable="true"
    app:maxWidth="480dp"
    android:layout_gravity="center_horizontal"
    style="@style/Widget.Material3.BottomSheet.Modal"
    android:focusable="true">

    <com.google.android.material.bottomsheet.BottomSheetDragHandleView
        android:id="@+id/drag_handle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:focusableInTouchMode="true"
        android:clipToPadding="false"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/customization_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                android:textStyle="bold"
                android:paddingBottom="24dp"/>

            <!-- Размер шрифта -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/font_size"
                    android:textAppearance="?attr/textAppearanceTitleMedium" />

                <TextView
                    android:id="@+id/size_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/default_size_value"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorOnSurfaceVariant" />
            </LinearLayout>

            <com.google.android.material.slider.Slider
                android:id="@+id/size_seekbar"
                style="@style/Widget.Material3.Slider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" />

            <!-- Max Width (Динамический блок) -->
            <LinearLayout
                android:id="@+id/max_width_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Max Width"
                        android:textAppearance="?attr/textAppearanceTitleMedium" />

                    <TextView
                        android:id="@+id/max_width_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="100%"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <com.google.android.material.slider.Slider
                    android:id="@+id/max_width_seekbar"
                    style="@style/Widget.Material3.Slider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:valueFrom="0.0"
                    android:valueTo="100.0"
                    android:value="100.0" />
            </LinearLayout>

            <!-- Прозрачность -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingBottom="8dp"
                android:text="@string/transparency"
                android:textAppearance="?attr/textAppearanceTitleMedium" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <com.google.android.material.slider.Slider
                    android:id="@+id/transparency_seekbar"
                    style="@style/Widget.Material3.Slider"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="?attr/colorOutline"
                    app:strokeWidth="1dp">

                    <View
                        android:id="@+id/transparency_preview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/white" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Шрифты и свойства -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/font_recycler_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="16dp" />

            <TextView
                android:id="@+id/variable_properties_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:text="Variable Properties"
                android:textAppearance="?attr/textAppearanceTitleMedium" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="16dp">

                <!-- Вес (Weight) -->
                <LinearLayout
                    android:id="@+id/var_weight_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:text="Weight"
                        android:textAppearance="?attr/textAppearanceBodyMedium" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/var_weight_seekbar"
                        style="@style/Widget.Material3.Slider"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:valueFrom="1.0"
                        android:valueTo="1000.0"
                        android:value="400.0" />

                    <TextView
                        android:id="@+id/var_weight_value"
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="400"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <!-- Ширина (Width) -->
                <LinearLayout
                    android:id="@+id/var_width_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:text="Width"
                        android:textAppearance="?attr/textAppearanceBodyMedium" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/var_width_seekbar"
                        style="@style/Widget.Material3.Slider"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:valueFrom="0.0"
                        android:valueTo="200.0"
                        android:value="100.0"/>

                    <TextView
                        android:id="@+id/var_width_value"
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="100"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <!-- Округлость (Roundness) -->
                <LinearLayout
                    android:id="@+id/var_roundness_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:text="Round"
                        android:textAppearance="?attr/textAppearanceBodyMedium" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/var_roundness_seekbar"
                        style="@style/Widget.Material3.Slider"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:valueFrom="0.0"
                        android:valueTo="100.0"
                        android:value="0.0"/>

                    <TextView
                        android:id="@+id/var_roundness_value"
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="0"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:dividerColor="?attr/colorOutlineVariant" />

            <!-- Цвет -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Color"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:paddingBottom="12dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/color_recycler_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:clipToPadding="false"
                android:paddingBottom="16dp"/>

            <!-- Переключатели (Свитчи) -->
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/edit_background_switch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="12dp"
                android:text="@string/edit_background"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:visibility="gone"
                tools:visibility="visible"/>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/night_shift_switch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="12dp"
                android:text="@string/night_shift"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:checked="false" />

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="16dp"
                app:dividerColor="?attr/colorOutlineVariant" />

            <!-- Выравнивание: Горизонтальное -->
            <TextView
                android:id="@+id/alignment_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/horizontal_alignment"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:paddingBottom="12dp" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/alignment_toggle_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="16dp"
                app:singleSelection="true">

                <Button
                    android:id="@+id/left_button"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:checked="true"
                    app:iconGravity="textStart"
                    app:icon="@drawable/align_horizontal_left"/>

                <Button
                    android:id="@+id/center_button"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:iconGravity="textStart"
                    app:icon="@drawable/align_horizontal_center"/>

                <Button
                    android:id="@+id/right_button"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:iconGravity="textStart"
                    app:icon="@drawable/align_horizontal_right"/>
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <!-- Выравнивание: Вертикальное -->
            <TextView
                android:id="@+id/vertical_alignment_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/vertical_alignment"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:paddingBottom="12dp" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/vertical_alignment_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="24dp"
                app:singleSelection="true">

                <Button
                    android:id="@+id/align_top_button"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/align_top"/>

                <Button
                    android:id="@+id/align_center_vertical_button"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:checked="true"
                    android:text="@string/align_center" />

                <Button
                    android:id="@+id/align_bottom_button"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/align_bottom"/>
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <!-- Выравнивание текста (Gravity) -->
            <TextView
                android:id="@+id/gravity_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/text_alignment"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:paddingBottom="12dp"
                android:visibility="visible"/>

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/text_gravity_toggle_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="16dp"
                app:singleSelection="true"
                android:visibility="visible">

                <Button
                    android:id="@+id/gravity_left_button"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:iconGravity="textStart"
                    app:icon="@drawable/align_horizontal_left" />

                <Button
                    android:id="@+id/gravity_center_button"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:iconGravity="textStart"
                    app:icon="@drawable/align_horizontal_center"/>

                <Button
                    android:id="@+id/gravity_right_button"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:iconGravity="textStart"
                    app:icon="@drawable/align_horizontal_right"/>
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="16dp"
                app:dividerColor="?attr/colorOutlineVariant" />

            <!-- Порядок виджетов -->
            <TextView
                android:id="@+id/widget_order_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/widget_order"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:paddingBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="16dp">

                <Button
                    android:id="@+id/move_up_button"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="@string/widget_order_up" />

                <Button
                    android:id="@+id/move_down_button"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="@string/widget_order_down" />
            </LinearLayout>

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="16dp"
                app:dividerColor="?attr/colorOutlineVariant" />

            <!-- Дополнительные настройки (Свободный режим, Сетка, Коллизии) -->
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/free_mode_switch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/free_mode_switch"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="?attr/colorError"
                android:paddingVertical="12dp"
                android:checked="false" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/grid_snap_switch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/snap_to_grid"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:paddingVertical="12dp"
                android:checked="true" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/ignore_collision_switch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/ignore_collision"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:paddingVertical="12dp"
                android:checked="false" />

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="16dp"
                app:dividerColor="?attr/colorOutlineVariant" />

            <!-- Форматы времени и даты -->
            <TextView
                android:id="@+id/time_format_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/time_format"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:paddingBottom="12dp"/>

            <RadioGroup
                android:id="@+id/time_format_radio_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="16dp">

                <RadioButton
                    android:id="@+id/time_24_radio"
                    style="@style/Widget.Material3.CompoundButton.RadioButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="24dp"
                    android:text="@string/time_24" />

                <RadioButton
                    android:id="@+id/time_12_radio"
                    style="@style/Widget.Material3.CompoundButton.RadioButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/time_12" />
            </RadioGroup>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/show_am_pm_switch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/show_am_pm"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:paddingVertical="8dp"
                android:layout_marginBottom="16dp"
                android:checked="false" />

            <TextView
                android:id="@+id/date_format_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/date_format"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:paddingBottom="12dp"/>

            <RadioGroup
                android:id="@+id/date_format_radio_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="16dp">

                <RadioButton
                    android:id="@+id/date_format_1"
                    style="@style/Widget.Material3.CompoundButton.RadioButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="@string/date_format_short" />

                <RadioButton
                    android:id="@+id/date_format_2"
                    style="@style/Widget.Material3.CompoundButton.RadioButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="@string/date_format_medium" />

                <RadioButton
                    android:id="@+id/date_format_3"
                    style="@style/Widget.Material3.CompoundButton.RadioButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/date_format_long" />
            </RadioGroup>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Нижняя панель с кнопками -->
    <LinearLayout
        android:id="@+id/buttons_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="?attr/colorSurfaceContainer"
        android:elevation="8dp"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp">

        <Button
            android:id="@+id/cancel_button"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/cancel" />

        <Space
            android:layout_width="16dp"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/apply_button"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/apply" />
    </LinearLayout>

</LinearLayout>